{
	"luci-app-opentether": {
		"description": "OpenTether LuCI interface",
		"read": {
			"ubus": {
				"service": ["list"]
			},
			"file": {
				"/etc/resolv.conf":                  ["read"],
				"/var/log/*":                        ["read"],
				"/tmp/opentether-tunnel-*.pid":      ["read"],
				"/proc/*/status":                    ["read"],
				"/usr/bin/hev-socks5-tunnel":        ["read"],
				"/etc/hev-socks5-tunnel/devices/*":  ["read"]
			},
			"uci": ["network", "firewall", "dhcp", "opentether"]
		},
		"write": {
			"file": {
				"/usr/lib/opentether/setup.sh":  ["exec"],
				"/etc/init.d/opentether":        ["exec"],
				"/usr/bin/adb":                  ["exec"],
				"/usr/bin/ip":                   ["exec"],
				"/sbin/ip":                      ["exec"],
				"/usr/bin/logread":              ["exec"],
				"/sbin/logread":                 ["exec"],
				"/usr/bin/pgrep":                ["exec"],
				"/usr/bin/curl":                 ["exec"],
				"/usr/bin/apk":                  ["exec"],
				"/sbin/uci":                     ["exec"]
			},
			"uci": ["network", "firewall", "dhcp", "opentether"]
		}
	}
}
